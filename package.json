{
  "name": "dreame-launcher",
  "version": "0.1.7",
  "description": "Dreame Launcher - a smooth custom Minecraft launcher.",
  "main": "main.js",
  "dreame": {
    "githubRepo": "dreame123/DreameLauncher"
  },
  "scripts": {
    "start": "electron .",
    "fix:electron": "node scripts/fix-electron.js",
    "make:icons": "powershell -ExecutionPolicy Bypass -File \"%cd%\\scripts\\generate-icons.ps1\"",
    "build": "npm run make:icons && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "com.dreame.launcher",
    "productName": "Dreame Launcher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build/icon.ico",
      "build/icon-256.png",
      "node_modules/skinview3d/bundles/skinview3d.bundle.js",
      "node_modules/skinview3d/assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Dreame Launcher",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "include": "build/installer-shortcuts.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "trustedDependencies": [
    "electron"
  ],
  "allowScripts": {
    "electron@31.7.7": true
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "skinview3d": "^3.4.2",
    "three": "^0.184.0",
    "xal-node": "^1.1.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
